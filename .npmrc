# VitePress reads markdown from /docs at the repo root (outside the
# apps/docs/ workspace). Vite resolves modules walking up from there and
# needs to find Vue, so we hoist anything Vue-related to the root
# node_modules. Without this VitePress builds fail with
# "Rollup failed to resolve import 'vue/server-renderer'".
public-hoist-pattern[]=*vue*
public-hoist-pattern[]=vitepress
public-hoist-pattern[]=@vue/*
