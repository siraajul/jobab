# Backend API base URL (NestJS app from /backend)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Until real auth lands, the frontend sends this org id on every request.
# After `npm run seed` in /backend, set this to the seeded id (`org_rongdhonu`).
NEXT_PUBLIC_ORG_ID=org_rongdhonu

# Stub auth password. Anyone with this can use the dashboard.
DEV_PASSWORD=change-me
