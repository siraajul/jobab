{
  "expo": {
    "name": "Jobab",
    "slug": "jobab-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "jobab",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jobab.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Take a photo of a customer's product reference."
      }
    },
    "android": {
      "package": "com.jobab.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F2"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#1F6E47"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://localhost:3000"
    }
  }
}
