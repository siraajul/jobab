// Jobab — Phase 1 schema (Section 3 of the build spec).
// Multi-tenant from day 1 (organizations); RBAC + multi-page tables included so
// Phase 2 (memberships, multi-page, comments, device tokens) drops in without rewrites.
//
// pgvector columns are declared via Unsupported("vector") so generation works
// without the extension being installed locally; enable with:
//   CREATE EXTENSION IF NOT EXISTS vector;

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum OrgStatus {
  onboarding
  active
  paused
}

enum CatalogSource {
  shopify
  woocommerce
  csv
}

enum MemberRole {
  owner
  admin
  agent
}

enum Platform {
  facebook
  instagram
  whatsapp
}

enum PageStatus {
  connected
  error
  disconnected
}

enum Direction {
  in
  out
}

enum Sender {
  customer
  agent
  human
}

enum ConversationStatus {
  bot
  needs_human
  human
  closed
}

enum OrderStatus {
  created
  confirmed
  shipped
  delivered
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
}

enum CommentIntent {
  price
  buy
  question
  other
  spam
}

enum CommentReplyMode {
  ai
  manual
  off
}

enum DevicePlatform {
  ios
  android
}

model Organization {
  id                   String         @id @default(cuid())
  name                 String
  catalogSource        CatalogSource? @map("catalog_source")
  catalogCredentials   Json?          @map("catalog_credentials") // encrypted blob
  aiInstructions       String?        @map("ai_instructions")
  notificationPhone    String?        @map("notification_phone")
  status               OrgStatus      @default(onboarding)
  createdAt            DateTime       @default(now()) @map("created_at")

  memberships          Membership[]
  pages                Page[]
  products             Product[]
  conversations        Conversation[]
  comments             Comment[]
  orders               Order[]
  invites              Invite[]
  auditEvents          AuditEvent[]
  commentRules         CommentRule[]

  @@map("organizations")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?       @map("password_hash")
  createdAt     DateTime      @default(now()) @map("created_at")

  memberships   Membership[]
  assignments   Conversation[] @relation("AssignedUser")
  deviceTokens  DeviceToken[]
  sentInvites   Invite[]      @relation("InviteSender")
  auditEvents   AuditEvent[]

  @@map("users")
}

model Invite {
  id              String       @id @default(cuid())
  organizationId  String       @map("organization_id")
  email           String
  role            MemberRole
  tokenHash       String       @unique @map("token_hash")
  invitedById     String       @map("invited_by_id")
  acceptedAt      DateTime?    @map("accepted_at")
  expiresAt       DateTime     @map("expires_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy       User         @relation("InviteSender", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([email])
  @@map("invites")
}

model AuditEvent {
  id              String       @id @default(cuid())
  organizationId  String       @map("organization_id")
  actorUserId     String?      @map("actor_user_id")
  action          String       // "member.invited", "conversation.assigned", "settings.updated", …
  targetType      String?      @map("target_type")
  targetId        String?      @map("target_id")
  metadata        Json?
  createdAt       DateTime     @default(now()) @map("created_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor           User?        @relation(fields: [actorUserId], references: [id])

  @@index([organizationId, createdAt])
  @@map("audit_events")
}

model Membership {
  id              String       @id @default(cuid())
  userId          String       @map("user_id")
  organizationId  String       @map("organization_id")
  role            MemberRole
  createdAt       DateTime     @default(now()) @map("created_at")

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

model Page {
  id                 String         @id @default(cuid())
  organizationId     String         @map("organization_id")
  platform           Platform
  externalPageId     String         @map("external_page_id")
  accessToken        String         @map("access_token") // encrypted at rest
  webhookSubscribed  Boolean        @default(false) @map("webhook_subscribed")
  status             PageStatus     @default(connected)

  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  comments           Comment[]

  @@unique([platform, externalPageId])
  @@index([organizationId])
  @@map("pages")
}

model Product {
  id                String                       @id @default(cuid())
  organizationId    String                       @map("organization_id")
  externalId        String?                      @map("external_id")
  title             String
  description       String?
  price             Decimal                      @db.Decimal(12, 2)
  currency          String                       @default("BDT")
  imageUrl          String?                      @map("image_url")
  // pgvector columns — set dimension at migration time, e.g. vector(768)/vector(1536).
  textEmbedding     Unsupported("vector")?       @map("text_embedding")
  imageEmbedding    Unsupported("vector")?       @map("image_embedding")
  updatedAt         DateTime                     @updatedAt @map("updated_at")

  organization      Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variants          ProductVariant[]

  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  name       String
  sku        String?
  price      Decimal  @db.Decimal(12, 2)
  stockQty   Int      @default(0) @map("stock_qty")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model Conversation {
  id                       String              @id @default(cuid())
  organizationId           String              @map("organization_id")
  pageId                   String              @map("page_id")
  externalUserId           String              @map("external_user_id") // PSID / IG-scoped
  assignedUserId           String?             @map("assigned_user_id")
  customerName             String?             @map("customer_name")
  customerPhone            String?             @map("customer_phone")
  customerAddress          String?             @map("customer_address")
  status                   ConversationStatus  @default(bot)
  lastCustomerMessageAt    DateTime?           @map("last_customer_message_at")
  createdAt                DateTime            @default(now()) @map("created_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  page            Page         @relation(fields: [pageId], references: [id], onDelete: Cascade)
  assignedUser    User?        @relation("AssignedUser", fields: [assignedUserId], references: [id])
  messages        Message[]
  orders          Order[]
  agentRuns       AgentRun[]
  privateRepliedComments Comment[] @relation("PrivateReply")

  @@unique([pageId, externalUserId])
  @@index([organizationId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id              String        @id @default(cuid())
  conversationId  String        @map("conversation_id")
  direction       Direction
  sender          Sender
  content         String
  attachments     Json?
  raw             Json?
  createdAt       DateTime      @default(now()) @map("created_at")

  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentRuns       AgentRun[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Comment {
  id                          String         @id @default(cuid())
  organizationId              String         @map("organization_id")
  pageId                      String         @map("page_id")
  externalCommentId           String         @unique @map("external_comment_id")
  postId                      String         @map("post_id")
  commenterExternalId         String         @map("commenter_external_id")
  commenterName               String?        @map("commenter_name")
  content                     String
  intent                      CommentIntent?
  intentConfidence            Float?         @map("intent_confidence")
  publicReplyText             String?        @map("public_reply_text")
  publicReplySent             Boolean        @default(false) @map("public_reply_sent")
  publicReplyAt               DateTime?      @map("public_reply_at")
  privateReplySent            Boolean        @default(false) @map("private_reply_sent")
  privateReplyConversationId  String?        @map("private_reply_conversation_id")
  createdAt                   DateTime       @default(now()) @map("created_at")

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  page            Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  privateReply    Conversation? @relation("PrivateReply", fields: [privateReplyConversationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([pageId, postId])
  @@map("comments")
}

model CommentRule {
  id              String           @id @default(cuid())
  organizationId  String           @map("organization_id")
  intent          CommentIntent
  replyMode       CommentReplyMode @default(ai) @map("reply_mode")
  publicTemplate  String?          @map("public_template")
  privateAllowed  Boolean          @default(true) @map("private_allowed")
  createdAt       DateTime         @default(now()) @map("created_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, intent])
  @@map("comment_rules")
}

model Order {
  id              String         @id @default(cuid())
  organizationId  String         @map("organization_id")
  conversationId  String         @map("conversation_id")
  externalOrderId String?        @map("external_order_id")
  items           Json           // [{product_id, variant_id, qty, price}]
  customerName    String         @map("customer_name")
  customerPhone   String         @map("customer_phone")
  customerAddress String         @map("customer_address")
  total           Decimal        @db.Decimal(12, 2)
  currency        String         @default("BDT")
  paymentStatus   PaymentStatus  @default(pending) @map("payment_status")
  paymentLink     String?        @map("payment_link")
  status          OrderStatus    @default(created)
  createdAt       DateTime       @default(now()) @map("created_at")

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation    Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([conversationId])
  @@map("orders")
}

model AgentRun {
  id              String      @id @default(cuid())
  conversationId  String      @map("conversation_id")
  messageId       String?     @map("message_id")
  model           String
  inputTokens     Int         @default(0) @map("input_tokens")
  outputTokens    Int         @default(0) @map("output_tokens")
  costUsd         Decimal     @default(0) @db.Decimal(10, 6) @map("cost_usd")
  toolCalls       Json?       @map("tool_calls")
  latencyMs       Int         @default(0) @map("latency_ms")
  createdAt       DateTime    @default(now()) @map("created_at")

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message         Message?     @relation(fields: [messageId], references: [id])

  @@index([conversationId, createdAt])
  @@map("agent_runs")
}

model DeviceToken {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  platform  DevicePlatform
  token     String         @unique
  createdAt DateTime       @default(now()) @map("created_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}
