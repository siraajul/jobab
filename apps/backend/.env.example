# --- core ---
NODE_ENV=development
PORT=3000

# --- postgres ---
DATABASE_URL=postgresql://jobab:jobab@localhost:5432/jobab?schema=public

# --- redis / bullmq ---
REDIS_URL=redis://localhost:6379

# --- meta (facebook + instagram) ---
# META_APP_ID enables the OAuth "Connect with Facebook" button in /onboarding.
# Leave blank to keep the manual page-ID + token paste form as the only option.
META_APP_ID=
META_APP_SECRET=replace-me
META_VERIFY_TOKEN=replace-me
META_GRAPH_VERSION=v20.0
# When 1, MessengerService persists outgoing messages but does NOT call Graph.
# Useful for the local fake-webhook loop where there's no real PSID to message.
MESSENGER_DRY_RUN=1

# --- llm provider (Groq, OpenAI-compatible) ---
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=replace-me
LLM_MAX_ITERATIONS=5
LLM_MAX_OUTPUT_TOKENS=1024

# --- vision (multimodal, for §9 image-to-product) ---
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- embeddings (Jina v3 + clip v2 — Bengali-capable, free tier) ---
# Get a key at https://jina.ai/embeddings  (1024-dim, free credits on sign-up).
# Without this, image embeddings are skipped and the agent falls back to
# describe-then-search using the vision LLM only.
JINA_API_KEY=replace-me

# --- encryption (page tokens, catalog creds) ---
# 32-byte base64 key for AES-256-GCM
ENCRYPTION_KEY=replace-me-with-32-byte-base64
